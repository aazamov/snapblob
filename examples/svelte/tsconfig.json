{
  "extends": "@tsconfig/svelte/tsconfig.json",
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "resolveJsonModule": true,
    "allowJs": true,
    "checkJs": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "paths": {
      "snapblob/*": ["../../src/*"],
      "snapblob": ["../../src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.svelte"]
}
